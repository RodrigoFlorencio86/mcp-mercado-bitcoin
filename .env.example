# ===== REQUIRED FOR AUTHENTICATED OPERATIONS =====
MB_API_KEY=your_client_id_here
MB_API_SECRET=your_client_secret_here

# ===== OPERATION MODE =====
# readonly  → only public data + account queries (safest)
# trading   → adds order placement/cancellation (default)
# full      → adds withdrawals and wallet management (use with caution)
MB_OPERATION_MODE=trading

# ===== SECURITY GUARDS =====
# Auto-confirm dangerous operations without preview? (default: false)
# When false, the LLM must show a preview and get user approval before executing
MB_AUTO_CONFIRM=false

# Maximum value for a single order in BRL (leave empty for no limit)
MB_MAX_ORDER_BRL=

# Maximum total daily trading volume in BRL (leave empty for no limit)
MB_DAILY_LIMIT_BRL=

# Dry-run mode: simulate operations without executing (default: false)
MB_DRY_RUN=false
